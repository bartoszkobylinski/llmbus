# Copy to deploy/iggy.env (gitignored) and set a real password.
# Read by iggy-server.service (EnvironmentFile). IGGY_* overrides Iggy's built-in
# config, so the bare binary needs no config.toml. The worker's own .env MUST use
# the same values for IGGY_USERNAME / IGGY_PASSWORD, or it can't log in.

# TCP bind — localhost-only, port 8092 (8090=beziarnia, 8091=uvicorn taken). This is
# the address the worker/producers put in IGGY_ADDRESS. (HTTP/QUIC keep Iggy's
# localhost defaults on 3000/8080; llmbus only needs TCP.)
IGGY_TCP_ADDRESS=127.0.0.1:8092

# Root account, pinned on first start (0.8.0 randomizes it otherwise — applied only
# while IGGY_SYSTEM_PATH is empty; wipe it to reset creds). Iggy is localhost-only,
# but still don't ship iggy/iggy — use e.g. `openssl rand -hex 24`.
IGGY_ROOT_USERNAME=iggy
IGGY_ROOT_PASSWORD=CHANGE_ME

# Where Iggy persists streams/topics/offsets. Absolute; owned by the service user.
IGGY_SYSTEM_PATH=/var/lib/iggy
