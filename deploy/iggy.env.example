# Copy to deploy/iggy.env (gitignored) and set a real password.
# These pin the Iggy broker's root account on first start (0.8.0 randomizes it
# otherwise). The worker's own .env MUST use the same values for IGGY_USERNAME /
# IGGY_PASSWORD, or it can't log in. Iggy is localhost-only, but still don't ship
# iggy/iggy to prod — pick something real.
IGGY_ROOT_USERNAME=iggy
IGGY_ROOT_PASSWORD=CHANGE_ME
