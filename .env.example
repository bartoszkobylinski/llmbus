# Copy to .env (gitignored) and fill in. Loaded via python-dotenv.

# --- LLM provider credentials ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Iggy backbone ---
# DEV: local docker broker (docker compose up -d).
# PROD: VPS-local systemd broker on 127.0.0.1:8090 (see ARCHITECTURE.md §9b).
# Never point dev at the prod broker.
IGGY_ADDRESS=127.0.0.1:8090
IGGY_USERNAME=iggy
IGGY_PASSWORD=iggy

# --- Rate limits (per provider) ---
OPENAI_RPM=
OPENAI_TPM=
ANTHROPIC_RPM=
ANTHROPIC_TPM=

# --- Budgets (USD per project, optional) ---
# BUDGET_HATE_MODERATOR=
