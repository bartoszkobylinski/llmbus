# Copy to .env (gitignored) and fill in. Loaded via python-dotenv.

# --- LLM provider credentials ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Iggy backbone ---
# DEV: local docker broker (docker compose up -d) -> 8090.
# PROD: VPS-local systemd broker on 127.0.0.1:8092 (see ARCHITECTURE.md §9b) — NOT 8090,
# which is beziarnia's gunicorn on that box. Pointing the worker at 8090 there makes it
# talk to a web app; it has already happened once.
# Never point dev at the prod broker.
IGGY_ADDRESS=127.0.0.1:8090
IGGY_USERNAME=iggy
IGGY_PASSWORD=iggy

# --- Results store ---
# SQLite file the worker writes and producers poll (same host, §9b). Dev: local
# path; prod: an absolute path under the worker's systemd WorkingDirectory.
STORE_PATH=llmbus.db

# --- Rate limits (per provider) ---
OPENAI_RPM=
OPENAI_TPM=
ANTHROPIC_RPM=
ANTHROPIC_TPM=

# --- Worker run policy (worker host only; producers don't need these) ---
# Retry on transient failures (429/5xx/timeout): total attempts incl. the first,
# and exponential backoff base/cap in seconds (full jitter applied on top).
WORKER_MAX_ATTEMPTS=4
WORKER_BACKOFF_BASE_S=0.5
WORKER_BACKOFF_MAX_S=30
# Per-attempt model-call timeout, seconds.
WORKER_JOB_TIMEOUT_S=60
# Output tokens to reserve against the rate limit when a job omits max_tokens.
WORKER_DEFAULT_OUTPUT_TOKENS=512
# Broker handshake (connect + login) retry, kept SEPARATE from the job retry
# above: a cold or flaky broker wants many short attempts, a paid model call few
# long ones. Iggy binds its TCP port before it is protocol-ready, so the first
# connect after a restart can fail; without this the worker crashes and systemd
# restarts it 5s later. Exhausting these attempts still exits (systemd retries).
WORKER_CONNECT_MAX_ATTEMPTS=10
WORKER_CONNECT_BACKOFF_BASE_S=0.25
WORKER_CONNECT_BACKOFF_MAX_S=5
# Optional HMAC secret for signing worker→producer callbacks (§14 #19). When set, the
# worker signs each callback POST body (X-Llmbus-Signature-256: sha256=<hmac>) so the
# receiver can verify it (mirrors hate-mod's Meta-webhook signature). Blank/unset →
# callbacks POSTed unsigned (the v1 default for a localhost-only callback).
# WORKER_CALLBACK_SECRET=

# --- Budgets (USD per project, optional) ---
# BUDGET_HATE_MODERATOR=
